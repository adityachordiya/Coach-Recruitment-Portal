# Supabase Postgres connection string (use the pooler URL on port 6543 for serverless)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=your-random-secret-here

# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Comma-separated owner emails to receive the weekly digest
OWNER_EMAILS=aditya@ascendspeech.org,varun@ascendspeech.org
